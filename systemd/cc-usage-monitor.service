[Unit]
Description=Claude Code usage monitor (reads rate-limit cache + ccusage)
After=graphical-session.target

[Service]
Type=oneshot
WorkingDirectory=%h/Projects/cc-usage-tray
# Ensure ccusage (npm-installed via nvm) is on PATH. Adjust if your node lives elsewhere.
Environment=PATH=%h/.nvm/versions/node/v20/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=LANG=en_US.UTF-8
Environment=LC_ALL=en_US.UTF-8
# Optional ntfy push: uncomment and set both vars
#Environment=CLAUDE_USAGE_NTFY_URL=https://ntfy.sh
#Environment=CLAUDE_USAGE_NTFY_TOPIC=replace-with-your-private-topic
ExecStart=/usr/bin/python3 -m usage_monitor.main
StandardOutput=append:%h/.claude/usage_monitor/monitor.log
StandardError=append:%h/.claude/usage_monitor/monitor.log
